# Terraform working directories and provider binaries
**/.terraform/*

# Terraform state and plan artifacts
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Local variable values often contain secrets
*.tfvars

# Optional local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore lock files for standalone examples and local runs
**/.terraform.lock.hcl
